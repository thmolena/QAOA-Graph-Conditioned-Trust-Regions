{
  "schema_version": 2,
  "design_revision": "v2_iid_primary_draft",
  "status": "design_only_not_registered_not_run",
  "scientific_role": "future_confirmatory_protocol",
  "current_audit_may_be_used_for": [
    "motivation",
    "method development",
    "sample-size planning"
  ],
  "current_audit_may_not_be_used_for": [
    "confirmatory evidence for this protocol",
    "hyperparameter selection after registration",
    "claiming that a future risk gate passed"
  ],
  "registration_requirements": {
    "external_timestamp_required": true,
    "two_stage_external_timestamp": {
      "stage_1_before_primary_calibration": [
        "complete source-code archive",
        "environment lock",
        "iid graph-mixture sampler and random-number-generator pin",
        "all optimizer and noise hyperparameters",
        "exact 17-arm registry",
        "trained selector",
        "eight primary-support fallback arm identifiers",
        "pooled order-statistic rule",
        "primary and secondary analysis code",
        "alpha allocation and decision rule"
      ],
      "stage_2_after_calibration_before_primary_audit": [
        "stage-1 receipt hash",
        "primary calibration graph and outcome hashes",
        "pooled calibration threshold",
        "complete frozen audit decision object"
      ]
    },
    "runner_must_require_stage_1_receipt_before_calibration": true,
    "runner_must_require_stage_2_receipt_before_audit": true,
    "registration_blocked_while_any_arm_or_policy_pin_is_unresolved": true
  },
  "primary_target_mixture": {
    "unit": "graph",
    "sampling_mode": "iid_draws_from_declared_categorical_mixture",
    "calibration_and_audit_use_identical_mixture": true,
    "fixed_stratum_quotas": false,
    "cross_split_isomorphism_rejection": false,
    "duplicate_graphs": "retain_and_report_without_resampling",
    "calibration_draws": 400,
    "audit_draws": 1600,
    "random_number_generator_pin": "registration_blocking_until algorithm, library version, master seeds and substream construction are externally timestamped",
    "generator_implementation_pin": "registration_blocking_until generator source hash and networkx version are externally timestamped",
    "generators": {
      "erdos_renyi": {
        "model": "G(n,p)",
        "parameter_distribution": {
          "p": "Uniform[0.15,0.75]"
        }
      },
      "random_regular": {
        "model": "uniform random d-regular graph",
        "parameter_distribution": {
          "degree": "DiscreteUniform{2,3,4,5,6}"
        }
      },
      "barabasi_albert": {
        "model": "Barabasi-Albert",
        "parameter_distribution": {
          "attachment": "DiscreteUniform{1,2,3,4}"
        }
      },
      "watts_strogatz": {
        "model": "Watts-Strogatz",
        "parameter_distribution": {
          "degree": "DiscreteUniform{2,4,6,8}",
          "rewiring": "Uniform[0.02,0.95]"
        }
      }
    },
    "support": [
      {
        "support_id": "er_n12_p2",
        "graph_family": "erdos_renyi",
        "vertex_count": 12,
        "qaoa_depth": 2,
        "mixture_weight": 0.125
      },
      {
        "support_id": "er_n14_p2",
        "graph_family": "erdos_renyi",
        "vertex_count": 14,
        "qaoa_depth": 2,
        "mixture_weight": 0.125
      },
      {
        "support_id": "rr_n12_p2",
        "graph_family": "random_regular",
