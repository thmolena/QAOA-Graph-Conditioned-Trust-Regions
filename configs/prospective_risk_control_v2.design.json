  "primary_estimands_and_fwer": {
    "fwer_budget": 0.05,
    "maximum_harm_risk": 0.1,
    "multiplicity_scope": "only the three named primary endpoints below",
    "alpha_allocation": [
      {
        "endpoint_id": "mean_paired_aurc",
        "alpha": 0.02,
        "one_sided_confidence": 0.98,
        "estimand": "mean deployed-minus-support-fallback AURC over primary_target_mixture",
        "method": "one-sided 98% studentized iid bootstrap upper bound with 100000 resamples and a registration-pinned RNG substream",
        "pass_rule": "upper bound below zero"
      },
      {
        "endpoint_id": "joint_harm",
        "alpha": 0.015,
        "one_sided_confidence": 0.985,
        "estimand": "probability over primary_target_mixture of accepting and underperforming the registered support fallback",
        "method": "one-sided 98.5% Clopper-Pearson upper bound on all primary audit draws",
        "pass_rule": "upper bound at most 0.10"
      },
      {
        "endpoint_id": "conditional_harm",
        "alpha": 0.015,
        "one_sided_confidence": 0.985,
        "estimand": "probability of underperforming the registered support fallback conditional on acceptance",
        "method": "one-sided 98.5% Clopper-Pearson upper bound conditional on the realized accepted count",
        "pass_rule": "at least 100 accepted draws and upper bound at most 0.10"
      }
    ],
    "allocated_alpha_sum": 0.05,
    "minimum_accepted_draws": 100,
    "zero_harm_minimum_accepted_needed_to_make_conditional_pass_possible": 40,
    "all_three_primary_endpoints_must_pass": true,
    "no_subgroup_or_secondary_endpoint_is_in_this_fwer_family": true
  },
  "secondary_descriptive_stress_policies": {
    "inferential_status": "mandatory_directional_or_stress_gates_not_separate_95pct_fwer_claims",
