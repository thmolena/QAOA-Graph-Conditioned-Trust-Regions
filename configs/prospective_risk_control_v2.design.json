      },
      {
        "support_id": "ws_n14_p2",
        "graph_family": "watts_strogatz",
        "vertex_count": 14,
        "qaoa_depth": 2,
        "mixture_weight": 0.125
      }
    ]
  },
  "primary_policy": {
    "selector": "fit on development outcomes only and externally timestamp its coefficients before primary calibration and audit outcomes",
    "calibration": {
      "population": "400 iid draws from primary_target_mixture",
      "nominal_miscoverage": 0.1,
      "threshold": "single pooled one-sided order statistic at rank ceil((n_calibration+1)*(1-nominal_miscoverage))",
      "decision_function_fixed_before_calibration_outcomes": true,
      "audit_reuses_no_calibration_outcome_except_the_frozen_threshold": true
    },
    "fallback_selection_rule": "within each support point, choose the arm with minimum development-only mean AURC; break exact ties by arm_registry order; freeze the selected arm id before primary calibration",
    "fallback_registry": [
      {
        "support_id": "er_n12_p2",
        "registered_arm_id": null,
        "registration_blocker": "populate from development-only fallback rule before external registration"
      },
      {
